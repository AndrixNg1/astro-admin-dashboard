---
import ResourceTable from "../components/dashboard/ResourceTable.astro";
import { projects } from "../data/projects";
import DashboardLayout from "../layouts/DashboardLayout.astro";
const columns = [
  { key: "name", label: "Projet" },
  { key: "client", label: "Client" },
  { key: "progress", label: "Progression (%)" },
  { key: "status", label: "Statut" },
];
---

<DashboardLayout title="Projets">
  <ResourceTable
    title="Projets"
    description="Gérez et suivez vos projets actifs."
    {columns}
    rows={projects}
    caption="Liste des projets"
  />
</DashboardLayout>
