---
import ResourceTable from "../components/dashboard/ResourceTable.astro";
import { orders } from "../data/orders";
import DashboardLayout from "../layouts/DashboardLayout.astro";

const columns = [
  { key: "id", label: "Commande" },
  { key: "customer", label: "Client" },
  { key: "date", label: "Date" },
  { key: "total", label: "Total" },
  { key: "payment", label: "Paiement" },
  { key: "status", label: "Statut" },
];
---

<DashboardLayout title="Commandes">
  <ResourceTable
    title="Commandes"
    description="Suivez les paiements, la préparation et la livraison des commandes."
    {columns}
    rows={orders}
    caption="Liste des commandes"
  />
</DashboardLayout>
