---
import ResourceTable from "../components/dashboard/ResourceTable.astro";
import { products } from "../data/products";
import DashboardLayout from "../layouts/DashboardLayout.astro";

const columns = [
  { key: "name", label: "Produit" },
  { key: "category", label: "Catégorie" },
  { key: "price", label: "Prix" },
  { key: "stock", label: "Stock" },
  { key: "status", label: "Disponibilité" },
];
---

<DashboardLayout title="Produits">
  <ResourceTable
    title="Catalogue produits"
    description="Consultez les prix, les catégories et les niveaux de stock."
    {columns}
    rows={products}
    caption="Catalogue des produits"
  />
</DashboardLayout>
