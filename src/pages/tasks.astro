---
import ResourceTable from "../components/dashboard/ResourceTable.astro";
import { tasks } from "../data/tasks";
import DashboardLayout from "../layouts/DashboardLayout.astro";
const columns = [
  { key: "title", label: "Tâche" },
  { key: "assignee", label: "Responsable" },
  { key: "dueDate", label: "Échéance" },
  { key: "priority", label: "Priorité" },
  { key: "status", label: "Statut" },
];
---

<DashboardLayout title="Tâches">
  <ResourceTable
    title="Tâches"
    description="Organisez le travail de votre équipe."
    {columns}
    rows={tasks}
    caption="Liste des tâches"
  />
</DashboardLayout>
