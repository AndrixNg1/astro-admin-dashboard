---
import Button from "../components/ui/Button.astro";
import Card from "../components/ui/Card.astro";
import Input from "../components/ui/Input.astro";
import PageHeader from "../components/ui/PageHeader.astro";
import DashboardLayout from "../layouts/DashboardLayout.astro";
import { User, Shield } from "@lucide/astro";
---

<DashboardLayout title="Paramètres">
  <PageHeader
    title="Paramètres"
    description="Configurez votre profil de gestionnaire et la sécurité de la boutique."
  />
  
  <div class="mt-8 grid gap-8 lg:grid-cols-4 relative">
    <div class="hidden lg:block lg:col-span-1">
      <div class="sticky top-28">
        <nav id="settings-nav" class="space-y-1.5">
          <a href="#profile" data-target="profile" class="nav-link group flex items-center gap-3 px-4 py-2.5 text-sm font-semibold rounded-xl transition-all bg-primary/10 text-primary">
            <User size={18} stroke-width={2.5} class="icon" />
            Profil gestionnaire
          </a>
          <a href="#security" data-target="security" class="nav-link group flex items-center gap-3 px-4 py-2.5 text-sm font-semibold rounded-xl transition-all text-muted hover:text-foreground hover:bg-surface-hover">
            <Shield size={18} stroke-width={2} class="icon transition-colors group-hover:text-foreground" />
            Sécurité
          </a>
        </nav>
      </div>
    </div>

    <div class="lg:col-span-3 space-y-8 pb-32">
      <section id="profile" data-settings-section class="scroll-mt-28">
        <Card>
          <div class="mb-6">
            <h2 class="text-xl font-bold text-foreground">Informations du gestionnaire</h2>
            <p class="text-sm text-muted mt-1">Mettez à jour les coordonnées du compte administrateur de la boutique.</p>
          </div>

          <form class="space-y-5">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
              <Input id="firstName" label="Prénom" value="Andrix" />
              <Input id="lastName" label="Nom" value="Ng" />
            </div>

            <Input
              id="email"
              label="Adresse e-mail"
              type="email"
              value="andrix@example.com"
            />

            <div class="pt-4 flex justify-end gap-3">
              <Button variant="ghost">Annuler</Button>
              <Button type="submit" variant="primary">Enregistrer les modifications</Button>
            </div>
          </form>
        </Card>
      </section>

      <section id="security" data-settings-section class="scroll-mt-28">
        <Card>
          <div class="mb-6">
            <h2 class="text-xl font-bold text-foreground">Mot de passe et Sécurité</h2>
            <p class="text-sm text-muted mt-1">Assurez-vous d'utiliser un mot de passe long et sécurisé pour votre compte.</p>
          </div>

          <form class="space-y-5">
            <Input id="currentPassword" label="Mot de passe actuel" type="password" />

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
              <Input id="newPassword" label="Nouveau mot de passe" type="password" />
              <Input id="confirmPassword" label="Confirmer le mot de passe" type="password" />
            </div>

            <div class="pt-4 flex justify-end">
              <Button type="submit" variant="secondary">Mettre à jour le mot de passe</Button>
            </div>
          </form>
        </Card>
      </section>
    </div>
  </div>
</DashboardLayout>

<script src="../assets/scripts/settings-navigation.ts"></script>
