---
import Card from "../components/ui/Card.astro";
import NotificationItem from "../components/dashboard/NotificationItem.astro";
import PageHeader from "../components/ui/PageHeader.astro";
import DashboardLayout from "../layouts/DashboardLayout.astro";
import { notifications } from "../data/notifications";
import { Check, Trash2 } from "@lucide/astro";
---

<DashboardLayout title="Notifications">
  <div class="flex flex-col sm:flex-row sm:items-end justify-between mb-8 gap-4">
    <PageHeader
      title="Notifications"
      description="Consultez et gérez toutes vos alertes et activités récentes."
    />
    <div class="flex gap-3">
      <button class="flex items-center gap-2 rounded-xl border border-border/50 bg-surface px-4 py-2 text-sm font-semibold text-muted shadow-sm transition-all hover:bg-surface-hover hover:text-foreground">
        <Check size={18} /> Tout marquer lu
      </button>
      <button class="flex items-center gap-2 rounded-xl bg-red-50 px-4 py-2 text-sm font-semibold text-red-600 transition-all hover:bg-red-100">
        <Trash2 size={18} /> Effacer
      </button>
    </div>
  </div>
  
  <Card class="p-0 overflow-hidden">
    <div class="divide-y divide-border/50">
      {notifications.map((notification) => <NotificationItem {notification} />)}
    </div>
  </Card>
</DashboardLayout>
