---
import PageHeader from '../components/ui/PageHeader.astro';
import StatCard from '../components/dashboard/StatCard.astro';
import ChartCard from '../components/dashboard/ChartCard.astro';
import ActivityFeed from '../components/dashboard/ActivityFeed.astro';
import DataTable from '../components/dashboard/DataTable.astro';
import { analyticsMetrics } from '../data/analytics';
import { orders } from '../data/orders';
import DashboardLayout from '../layouts/DashboardLayout.astro';
import RevenueChart from '../components/charts/RevenueChart.astro';
import ConversionChart from '../components/charts/ConversionChart.astro';

const recentActivities = [
  { id: 1, title: "Commande confirmée", description: "La commande CMD-1048 a été payée par carte.", time: "Il y a 5 min" },
  { id: 2, title: "Stock faible", description: "Il ne reste que 8 exemplaires du Sac Nomad.", time: "Il y a 2 heures" },
  { id: 3, title: "Nouveau client", description: "Marc Ilunga vient de créer son compte.", time: "Hier" },
  { id: 4, title: "Commande expédiée", description: "La commande CMD-1046 a quitté l'entrepôt.", time: "Il y a 2 jours" },
];

const orderColumns = [
  { key: "id", label: "Commande" },
  { key: "customer", label: "Client" },
  { key: "total", label: "Total" },
  { key: "status", label: "Statut" },
];
---

<DashboardLayout title="Vue d'ensemble">
	<PageHeader
		title="Vue d'ensemble"
		description="Pilotez les ventes et les opérations de votre boutique en temps réel."
	/>
	<div class="mt-8 grid gap-6 sm:grid-cols-2 xl:grid-cols-4">
		{analyticsMetrics.map((metric) => <StatCard {...metric} />)}
	</div>

	<div class="mt-8 grid gap-6 lg:grid-cols-3">
		<div class="lg:col-span-2">
			<ChartCard title="Chiffre d'affaires" description="Évolution des ventes sur les douze derniers mois.">
				<RevenueChart height={300} />
			</ChartCard>
		</div>
		<ChartCard title="Conversions" description="Évolution sur huit semaines.">
			<ConversionChart height={300} />
		</ChartCard>
	</div>

	<div class="mt-8 grid gap-6 lg:grid-cols-3">
		<div class="lg:col-span-2 space-y-6">
			<ChartCard title="Commandes récentes" description="Les dernières ventes enregistrées sur la boutique.">
				<DataTable columns={orderColumns} rows={orders.slice(0, 5)} caption="Commandes récentes" />
			</ChartCard>
		</div>
		
		<div class="space-y-6">
			<ChartCard title="Activité de la boutique" description="Les événements commerciaux récents.">
				<ActivityFeed activities={recentActivities} />
			</ChartCard>
		</div>
	</div>
</DashboardLayout>
