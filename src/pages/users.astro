---
import ResourceTable from "../components/dashboard/ResourceTable.astro";
import { users } from "../data/users";
import DashboardLayout from "../layouts/DashboardLayout.astro";
const columns = [
  { key: "name", label: "Nom" },
  { key: "email", label: "E-mail" },
  { key: "role", label: "Rôle" },
  { key: "status", label: "Statut" },
];
---

<DashboardLayout title="Utilisateurs">
  <ResourceTable
    title="Utilisateurs"
    description="Gérez les membres et leurs accès."
    {columns}
    rows={users}
    caption="Liste des utilisateurs"
  />
</DashboardLayout>
