---
import ChartCard from "../components/dashboard/ChartCard.astro";
import StatCard from "../components/dashboard/StatCard.astro";
import PageHeader from "../components/ui/PageHeader.astro";
import DashboardLayout from "../layouts/DashboardLayout.astro";
import { analyticsMetrics } from "../data/analytics";
import EChart from "../components/charts/EChart";
import { revenueChartOptions } from "../charts/RevenueChart";
import { trafficChartOptions } from "../charts/TrafficChart";
import { conversionChartOptions } from "../charts/ConversionChart";
---

<DashboardLayout title="Analytiques">
  <PageHeader
    title="Analytiques"
    description="Analysez vos performances et découvrez les tendances."
  />
  
  <div class="mt-8 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
    {analyticsMetrics.map((metric) => <StatCard {...metric} />)}
  </div>

  <div class="mt-8 grid gap-6 lg:grid-cols-2">
    <ChartCard title="Évolution des revenus" description="Performances sur les 12 derniers mois.">
      <EChart client:visible label="Évolution mensuelle des revenus" options={revenueChartOptions} />
    </ChartCard>
    
    <ChartCard title="Sources de trafic" description="Répartition des visites par canal d'acquisition.">
      <EChart client:visible label="Répartition des sources de trafic" options={trafficChartOptions} />
    </ChartCard>
  </div>

  <div class="mt-6">
    <ChartCard title="Taux de conversion" description="Progression des conversions au cours des huit dernières semaines.">
      <EChart client:visible label="Taux de conversion hebdomadaire" options={conversionChartOptions} height={300} />
    </ChartCard>
  </div>
</DashboardLayout>
