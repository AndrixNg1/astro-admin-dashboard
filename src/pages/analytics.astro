---
import ChartCard from "../components/dashboard/ChartCard.astro";
import StatCard from "../components/dashboard/StatCard.astro";
import PageHeader from "../components/ui/PageHeader.astro";
import DashboardLayout from "../layouts/DashboardLayout.astro";
import { analyticsMetrics } from "../data/analytics";
import RevenueChart from "../components/charts/RevenueChart.astro";
import TrafficChart from "../components/charts/TrafficChart.astro";
import ConversionChart from "../components/charts/ConversionChart.astro";
---

<DashboardLayout title="Analytiques">
  <PageHeader
    title="Analytiques"
    description="Analysez les ventes, l'acquisition et la conversion de votre boutique."
  />
  
  <div class="mt-8 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
    {analyticsMetrics.map((metric) => <StatCard {...metric} />)}
  </div>

  <div class="mt-8 grid gap-6 lg:grid-cols-2">
    <ChartCard title="Chiffre d'affaires" description="Ventes réalisées sur les 12 derniers mois.">
      <RevenueChart height={320} />
    </ChartCard>
    
    <ChartCard title="Canaux d'acquisition" description="Origine des visiteurs de la boutique en ligne.">
      <TrafficChart height={320} />
    </ChartCard>
  </div>

  <div class="mt-6">
    <ChartCard title="Taux de conversion" description="Progression des conversions au cours des huit dernières semaines.">
      <ConversionChart height={300} />
    </ChartCard>
  </div>
</DashboardLayout>
