---
import type { Activity } from "../../types";
interface Props {
  activities: Activity[];
}
const { activities }: Props = Astro.props;
---

<div class="relative border-l border-border/50 ml-3 space-y-6">
  {
    activities.map((activity) => (
      <div class="relative pl-6 transition-all duration-300 hover:translate-x-1 group">
        <span class="absolute -left-[5px] top-1.5 size-2.5 rounded-full bg-border transition-colors duration-300 group-hover:bg-primary group-hover:shadow-[0_0_8px_rgba(79,70,229,0.6)]" />
        <div>
          <p class="text-sm font-bold text-foreground transition-colors group-hover:text-primary">{activity.title}</p>
          <p class="mt-1 text-sm text-muted">{activity.description}</p>
          <time class="mt-1.5 block text-xs font-semibold uppercase tracking-wider text-muted/70 group-hover:text-primary/70">
            {activity.time}
          </time>
        </div>
      </div>
    ))
  }
</div>
