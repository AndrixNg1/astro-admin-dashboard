---
import Card from "../ui/Card.astro";
interface Props {
  label: string;
  value: string;
  change?: number;
}
const { label, value, change } = Astro.props;
---

<Card class="group relative overflow-hidden">
  <div class="absolute -right-6 -top-6 size-24 rounded-full bg-primary/5 blur-2xl transition-all duration-500 group-hover:bg-primary/10"></div>
  <p class="text-xs font-bold uppercase tracking-wider text-muted/80">{label}</p>
  <div class="mt-4 flex items-end justify-between gap-3 relative z-10">
    <p class="text-3xl font-extrabold tracking-tight text-foreground">{value}</p>
    {
      change !== undefined && (
        <span
          class:list={[
            "flex items-center gap-1 rounded-full px-2.5 py-1 text-xs font-bold transition-colors",
            change > 0 ? "bg-emerald-500/10 text-emerald-600" : change < 0 ? "bg-red-500/10 text-red-600" : "bg-slate-500/10 text-slate-600",
          ]}
        >
          {change > 0 ? "+" : ""}
          {change}%
        </span>
      )
    }
  </div>
</Card>
