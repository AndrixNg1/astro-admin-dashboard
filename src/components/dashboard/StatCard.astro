---
import Card from "../ui/Card.astro";
interface Props { label: string; value: string; change?: number; }
const { label, value, change } = Astro.props;
---
<Card>
	<p class="text-sm font-medium text-muted">{label}</p>
	<div class="mt-2 flex items-end justify-between gap-3">
		<p class="text-2xl font-bold">{value}</p>
		{change !== undefined && <span class:list={["text-xs font-semibold", change >= 0 ? "text-emerald-600" : "text-red-600"]}>{change >= 0 ? "+" : ""}{change}%</span>}
	</div>
</Card>
