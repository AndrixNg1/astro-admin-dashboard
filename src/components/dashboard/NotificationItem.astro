---
import { Bell } from "@lucide/astro";
import type { Notification } from "../../types";

interface Props {
  notification: Notification;
  compact?: boolean;
}

const { notification, compact = false }: Props = Astro.props;
---

{compact ? (
  <article class:list={["group flex gap-3 rounded-xl p-3 transition-colors", notification.unread ? "bg-primary/5 hover:bg-primary/10" : "hover:bg-surface-hover"]}>
    <span class:list={["mt-1 size-2 shrink-0 rounded-full", notification.unread ? "bg-primary shadow-[0_0_8px_rgba(79,70,229,0.6)]" : "bg-muted/30"]}></span>
    <div>
      <h4 class="text-sm font-semibold text-foreground transition-colors group-hover:text-primary">{notification.title}</h4>
      <p class="mt-0.5 text-xs text-muted">{notification.description}</p>
      <time class:list={["mt-1.5 block text-[10px] font-bold uppercase tracking-wider", notification.unread ? "text-primary/70" : "text-muted/70"]}>{notification.time}</time>
    </div>
  </article>
) : (
  <article class:list={["flex items-start gap-4 p-5 transition-colors hover:bg-surface-hover/50", notification.unread && "bg-primary/5"]}>
    <div class="mt-1 flex size-10 shrink-0 items-center justify-center rounded-full border border-border/50 bg-surface shadow-[0_2px_8px_rgba(0,0,0,0.04)]">
      <Bell size={18} class={notification.unread ? "text-primary" : "text-muted"} aria-hidden="true" />
    </div>
    <div class="flex-1">
      <div class="flex flex-col justify-between gap-1 sm:flex-row sm:items-center">
        <h3 class:list={["text-sm font-bold", notification.unread ? "text-primary" : "text-foreground"]}>{notification.title}</h3>
        <time class="text-xs font-semibold uppercase tracking-wider text-muted">{notification.time}</time>
      </div>
      <p class="mt-1 text-sm text-muted">{notification.description}</p>
    </div>
    {notification.unread && <span class="mt-2 size-2.5 shrink-0 rounded-full bg-primary shadow-[0_0_8px_rgba(79,70,229,0.6)]"><span class="sr-only">Non lue</span></span>}
  </article>
)}
