---
import type { TableColumn, TableRow } from "../../types";
interface Props {
  columns: TableColumn[];
  rows: TableRow[];
  caption?: string;
}
const { columns, rows, caption = "Données" }: Props = Astro.props;

const getCellValue = (row: TableRow, key: string): string | number => {
  const value = (row as Record<string, unknown>)[key];

  return typeof value === "string" || typeof value === "number"
    ? value
    : String(value ?? "");
};
---

<div class="overflow-x-auto rounded-2xl border border-border/50 bg-surface shadow-[0_8px_30px_rgb(0,0,0,0.04)]">
  <table class="w-full text-left text-sm">
    <caption class="sr-only">{caption}</caption>
    <thead class="border-b border-border/50 bg-surface-hover/50 text-xs font-bold uppercase tracking-wider text-muted">
      <tr>
        {columns.map((column) => (
          <th scope="col" class="px-6 py-4">
            {column.label}
          </th>
        ))}
      </tr>
    </thead>
    <tbody class="divide-y divide-border/50">
      {rows.map((row) => (
        <tr class="group transition-colors duration-200 hover:bg-primary/5">
          {columns.map((column) => (
            <td class="whitespace-nowrap px-6 py-4 font-medium text-foreground transition-colors group-hover:text-primary">
              {getCellValue(row, column.key)}
            </td>
          ))}
        </tr>
      ))}
    </tbody>
  </table>
</div>
