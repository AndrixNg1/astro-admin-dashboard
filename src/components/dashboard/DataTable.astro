---
interface Column {
  key: string;
  label: string;
}
interface Props {
  columns: Column[];
  rows: object[];
  caption?: string;
}
const { columns, rows, caption = "Données" }: Props = Astro.props;

const getCellValue = (row: object, key: string): string | number => {
  const value = (row as Record<string, unknown>)[key];

  return typeof value === "string" || typeof value === "number"
    ? value
    : String(value ?? "");
};
---

<div class="overflow-x-auto rounded-xl border bg-surface">
  <table class="w-full text-left text-sm">
    <caption class="sr-only">{caption}</caption>
    <thead
      class="border-b bg-slate-50 text-xs uppercase tracking-wide text-muted"
      ><tr
        >{
          columns.map((column) => (
            <th scope="col" class="px-5 py-3 font-semibold">
              {column.label}
            </th>
          ))
        }</tr
      ></thead
    >
    <tbody class="divide-y"
      >{
        rows.map((row) => (
          <tr class="hover:bg-slate-50">
            {columns.map((column) => (
              <td class="whitespace-nowrap px-5 py-4">
                {getCellValue(row, column.key)}
              </td>
            ))}
          </tr>
        ))
      }</tbody
    >
  </table>
</div>
