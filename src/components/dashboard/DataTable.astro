---
interface Column { key: string; label: string; }
interface Props { columns: Column[]; rows: Record<string, string | number>[]; caption?: string; }
const { columns, rows, caption = "Données" } = Astro.props;
---
<div class="overflow-x-auto rounded-xl border bg-surface">
	<table class="w-full text-left text-sm">
		<caption class="sr-only">{caption}</caption>
		<thead class="border-b bg-slate-50 text-xs uppercase tracking-wide text-muted"><tr>{columns.map((column) => <th scope="col" class="px-5 py-3 font-semibold">{column.label}</th>)}</tr></thead>
		<tbody class="divide-y">{rows.map((row) => <tr class="hover:bg-slate-50">{columns.map((column) => <td class="whitespace-nowrap px-5 py-4">{row[column.key]}</td>)}</tr>)}</tbody>
	</table>
</div>
