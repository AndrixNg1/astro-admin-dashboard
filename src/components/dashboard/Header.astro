---
import { Menu, Search, Bell } from "@lucide/astro";
import { notifications } from "../../data/notifications";
import NotificationItem from "./NotificationItem.astro";

const recentNotifications = notifications.slice(0, 2);
const unreadCount = notifications.filter((notification) => notification.unread).length;
---

<header
  class="sticky top-0 z-40 flex h-20 w-full items-center justify-between border-b border-border/50 bg-surface/80 px-4 backdrop-blur-xl sm:px-8 transition-all"
>
  <div class="flex items-center gap-4">
    <button
      type="button"
      id="mobile-menu-btn"
      aria-controls="sidebar"
      aria-expanded="false"
      class="rounded-xl p-2 text-muted transition-all hover:bg-surface-hover hover:text-foreground lg:hidden"
      aria-label="Ouvrir le menu"><Menu size={24} aria-hidden="true" /></button
    >
    
    <div class="hidden max-w-md lg:block">
      <div class="relative group">
        <div class="pointer-events-none absolute inset-y-0 left-0 flex items-center pl-3 text-muted transition-colors group-focus-within:text-primary">
          <Search size={18} aria-hidden="true" />
        </div>
        <input
          type="text"
          class="block w-64 rounded-xl border-0 bg-surface-hover py-2.5 pl-10 pr-3 text-sm text-foreground transition-all focus:w-80 focus:bg-surface focus:ring-2 focus:ring-primary/20 focus:outline-none"
          placeholder="Rechercher..."
        />
      </div>
    </div>
  </div>

  <div class="flex items-center gap-4 sm:gap-6">
    <button
      type="button"
      class="rounded-xl p-2 text-muted transition-all hover:bg-surface-hover hover:text-primary lg:hidden"
      aria-label="Rechercher"><Search size={22} aria-hidden="true" /></button
    >

    <!-- Notifications -->
    <div class="relative">
      <button
        type="button"
        id="notifications-btn"
        aria-controls="notifications-modal"
        aria-expanded="false"
        class="relative rounded-xl p-2 text-muted transition-all hover:bg-surface-hover hover:text-primary"
        aria-label="Notifications"
      >
        <Bell size={22} aria-hidden="true" class="transition-transform hover:scale-110" />
        <span class="absolute right-2 top-2 flex size-2.5">
          <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-red-400 opacity-75"></span>
          <span class="relative inline-flex size-2.5 rounded-full bg-red-500"></span>
        </span>
      </button>

      <!-- Notification Modal -->
      <div id="notifications-modal" class="absolute right-0 top-full mt-2 hidden w-80 rounded-2xl border border-border/50 bg-surface/95 p-4 shadow-[0_8px_30px_rgb(0,0,0,0.12)] backdrop-blur-xl sm:w-96 origin-top-right transition-all">
        <div class="mb-4 flex items-center justify-between">
          <h3 class="text-base font-bold text-foreground">Notifications</h3>
          <span class="rounded-md bg-primary/10 px-2 py-0.5 text-xs font-bold text-primary">{unreadCount} nouvelle{unreadCount > 1 ? "s" : ""}</span>
        </div>
        <div class="space-y-3">
          {recentNotifications.map((notification) => <NotificationItem {notification} compact />)}
        </div>
        <div class="mt-4 border-t border-border/50 pt-3 text-center">
          <a href="/notifications" class="text-sm font-bold text-primary hover:underline">Voir toutes les notifications</a>
        </div>
      </div>
    </div>

    <div class="h-8 w-[1px] bg-border/50"></div>

    <a href="/settings" class="flex items-center gap-3 rounded-xl p-1 pr-3 transition-all hover:bg-surface-hover">
      <div
        class="grid size-10 place-items-center rounded-xl bg-gradient-to-br from-primary to-indigo-600 text-sm font-semibold text-white shadow-md shadow-primary/20 transition-transform hover:scale-105"
      >
        AN
      </div>
      <div class="hidden text-left lg:block">
        <p class="text-sm font-semibold text-foreground">Andrix Ng</p>
        <p class="text-xs text-muted">Administrateur</p>
      </div>
    </a>
  </div>
</header>

<script src="../../assets/scripts/header-notifications.ts"></script>
