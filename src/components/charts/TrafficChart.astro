---
interface Props { height?: number }
const { height = 320 } = Astro.props;
---

<div
  data-traffic-chart
  class="chart-enter w-full rounded-xl"
  style={`height:${height}px`}
  role="img"
  aria-label="Répartition des canaux d'acquisition"
></div>

<script>
  const charts = document.querySelectorAll<HTMLDivElement>("[data-traffic-chart]:not([data-mounted])");

  const observer = new IntersectionObserver((entries) => {
    for (const entry of entries) {
      if (!entry.isIntersecting) continue;
      const container = entry.target as HTMLDivElement;
      container.dataset.mounted = "true";
      observer.unobserve(container);
      void import("../../assets/scripts/traffic-chart").then(({ mountTrafficChart }) => {
        mountTrafficChart(container);
      });
    }
  }, { rootMargin: "200px" });

  charts.forEach((chart) => observer.observe(chart));
</script>
