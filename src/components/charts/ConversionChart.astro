---
import { conversionRates } from "../../data/analytics";

interface Props { height?: number }
const { height = 300 } = Astro.props;
const max = 4.5;
---

<div class="chart-enter flex w-full items-end gap-2 pt-8 sm:gap-3" style={`height:${height}px`} role="img" aria-label="Évolution du taux de conversion sur huit semaines">
  {conversionRates.map((value, index) => (
    <div class="group flex h-full min-w-0 flex-1 flex-col justify-end gap-2">
      <div class="relative flex flex-1 items-end rounded-lg bg-surface-hover/60 transition-colors duration-300 group-hover:bg-indigo-50">
        <button
          class="relative w-full rounded-lg bg-gradient-to-t from-indigo-700 to-indigo-500 shadow-sm outline-none transition-all duration-300 group-hover:-translate-y-1 group-hover:from-indigo-800 group-hover:to-indigo-400 group-hover:shadow-lg group-hover:shadow-indigo-500/20 focus-visible:-translate-y-1 focus-visible:ring-2 focus-visible:ring-indigo-400 focus-visible:ring-offset-2"
          style={`height:${(value / max) * 100}%; animation-delay:${index * 45}ms`}
          aria-label={`Semaine ${index + 1} : ${value}%`}
        >
          <span class="absolute -top-9 left-1/2 z-10 -translate-x-1/2 translate-y-1 whitespace-nowrap rounded-lg bg-slate-900 px-2.5 py-1.5 text-[10px] font-bold text-white opacity-0 shadow-lg transition-all duration-200 group-hover:translate-y-0 group-hover:opacity-100 group-focus-within:translate-y-0 group-focus-within:opacity-100">{value}%</span>
        </button>
      </div>
      <span class="text-center text-[10px] font-medium text-muted sm:text-xs">S{index + 1}</span>
    </div>
  ))}
</div>
