---
import { monthlyRevenue } from "../../data/analytics";

interface Props { height?: number }
const { height = 300 } = Astro.props;
const labels = ["Jan", "Fév", "Mar", "Avr", "Mai", "Juin", "Juil", "Août", "Sep", "Oct", "Nov", "Déc"];
const width = 720;
const chartHeight = 220;
const top = 16;
const bottom = 28;
const min = 20;
const max = 90;
const points = monthlyRevenue.map((value, index) => ({
  x: (index / (monthlyRevenue.length - 1)) * width,
  y: top + ((max - value) / (max - min)) * (chartHeight - top - bottom),
  value,
  label: labels[index],
}));
const line = points.map(({ x, y }) => `${x},${y}`).join(" ");
const area = `0,${chartHeight - bottom} ${line} ${width},${chartHeight - bottom}`;
---

<div class="chart-enter revenue-chart relative w-full" style={`height:${height}px`} role="img" aria-label="Évolution mensuelle du chiffre d'affaires">
  <svg viewBox={`-8 0 ${width + 16} ${chartHeight}`} class="pointer-events-none h-full w-full overflow-visible" preserveAspectRatio="none">
    <defs>
      <linearGradient id="revenue-area" x1="0" y1="0" x2="0" y2="1">
        <stop offset="0" stop-color="#4f46e5" stop-opacity=".28" />
        <stop offset="1" stop-color="#4f46e5" stop-opacity="0" />
      </linearGradient>
    </defs>
    {[30, 50, 70, 90].map((value) => {
      const y = top + ((max - value) / (max - min)) * (chartHeight - top - bottom);
      return <line x1="0" x2={width} y1={y} y2={y} stroke="currentColor" class="text-border/70" stroke-dasharray="4 6" vector-effect="non-scaling-stroke" />;
    })}
    <polygon points={area} fill="url(#revenue-area)" />
    <polyline points={line} fill="none" stroke="#4f46e5" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round" vector-effect="non-scaling-stroke" />
    {points.map((point, index) => (
      <circle cx={point.x} cy={point.y} r={index === points.length - 1 ? 5 : 3} fill="#4f46e5" stroke="white" stroke-width="2" vector-effect="non-scaling-stroke" />
    ))}
    {labels.map((label, index) => index % 2 === 0 && (
      <text x={(index / 11) * width} y={chartHeight - 4} text-anchor="middle" class="fill-muted text-[10px]">{label}</text>
    ))}
  </svg>
  <div class="absolute inset-x-0 bottom-[13%] top-[7%] grid grid-cols-12">
    {points.map((point) => {
      const y = ((point.y - top) / (chartHeight - top - bottom)) * 100;
      return (
        <button class="revenue-point group relative cursor-crosshair outline-none" aria-label={`${point.label} : ${point.value} milliers de dollars`}>
          <span class="absolute inset-y-0 left-1/2 w-px -translate-x-1/2 bg-primary/20 opacity-0 transition-opacity duration-200 group-hover:opacity-100 group-focus-visible:opacity-100"></span>
          <span class="revenue-tooltip absolute left-1/2 z-10 -translate-x-1/2 -translate-y-[calc(100%+12px)] whitespace-nowrap rounded-lg bg-slate-900 px-3 py-2 text-xs font-semibold text-white opacity-0 shadow-xl transition-all duration-200 group-hover:-translate-y-[calc(100%+16px)] group-hover:opacity-100 group-focus-visible:-translate-y-[calc(100%+16px)] group-focus-visible:opacity-100" style={`top:${y}%`}>
            <span class="block text-[10px] font-medium text-slate-300">{point.label} 2026</span>{point.value} 000 $
          </span>
          <span class="absolute left-1/2 size-3 -translate-x-1/2 -translate-y-1/2 rounded-full border-[3px] border-white bg-primary opacity-0 shadow-md transition-all duration-200 group-hover:scale-125 group-hover:opacity-100 group-focus-visible:scale-125 group-focus-visible:opacity-100" style={`top:${y}%`}></span>
        </button>
      );
    })}
  </div>
</div>
