---
interface Props { label: string; }
const { label } = Astro.props;
---
<details class="relative inline-block">
	<summary class="cursor-pointer list-none rounded-lg border bg-white px-3 py-2 text-sm font-medium">{label}</summary>
	<div class="absolute right-0 z-20 mt-2 min-w-44 rounded-lg border bg-white p-2 shadow-lg"><slot /></div>
</details>
