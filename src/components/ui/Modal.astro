---
interface Props {
  id: string;
  title: string;
}
const { id, title } = Astro.props;
---

<dialog
  {id}
  class="m-auto w-[min(32rem,calc(100%-2rem))] rounded-xl border bg-white p-0 shadow-xl backdrop:bg-slate-950/40"
>
  <div class="border-b p-5"><h2 class="text-lg font-semibold">{title}</h2></div>
  <div class="p-5"><slot /></div>
</dialog>
