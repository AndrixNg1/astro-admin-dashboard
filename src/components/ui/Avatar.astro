---
interface Props { name: string; src?: string; size?: "sm" | "md" | "lg"; }
const { name, src, size = "md" } = Astro.props;
const sizes = { sm: "size-8 text-xs", md: "size-10 text-sm", lg: "size-12 text-base" };
const initials = name.split(" ").map((part: string) => part[0]).slice(0, 2).join("").toUpperCase();
---
{src ? <img src={src} alt={name} class:list={["rounded-full object-cover", sizes[size]]} /> : <span role="img" aria-label={name} class:list={["inline-grid place-items-center rounded-full bg-indigo-100 font-semibold text-primary", sizes[size]]}>{initials}</span>}
