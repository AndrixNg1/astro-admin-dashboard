---
interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;
---

<header>
  <h1 class="text-2xl font-bold tracking-tight sm:text-3xl">{title}</h1>
  {
    description && (
      <p class="mt-2 text-sm text-muted sm:text-base">{description}</p>
    )
  }
</header>
