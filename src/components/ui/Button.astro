---
interface Props {
  href?: string;
  type?: "button" | "submit" | "reset";
  variant?: "primary" | "secondary" | "danger" | "ghost";
  class?: string;
}
const { href, type = "button", variant = "primary", class: customClass = "" }: Props = Astro.props;

const styles = {
  primary: "bg-primary text-white shadow-md shadow-primary/20 hover:bg-primary-hover hover:shadow-lg hover:-translate-y-0.5",
  secondary: "border border-border/50 bg-surface text-foreground shadow-sm hover:bg-surface-hover hover:text-primary hover:-translate-y-0.5 hover:shadow-md",
  danger: "bg-red-500 text-white shadow-md shadow-red-500/20 hover:bg-red-600 hover:shadow-lg hover:-translate-y-0.5",
  ghost: "bg-transparent text-muted hover:bg-surface-hover hover:text-foreground",
};

const className = `inline-flex items-center justify-center gap-2 rounded-xl px-5 py-2.5 text-sm font-semibold transition-all duration-300 ease-out active:scale-95 ${styles[variant]} ${customClass}`;
---

{
  href ? (
    <a href={href} class={className}>
      <slot />
    </a>
  ) : (
    <button {type} class={className}>
      <slot />
    </button>
  )
}
